  "flow": {
    "actions": [
      {
        "title": {
          "en": "Activate Boost Mode"
        },
        "titleFormatted": {
          "en": "Activate the fan in Boost Mode for [[mins]] minutes"
        },
        "hint": {
          "en": "When activated, your fan will activate in Boost Mode for the duration selected"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sky"
          },
          {
            "type": "number",
            "name": "mins",
            "title": {
              "en": "Minutes"
            },
            "min": 1,
            "max": 120,
            "decimals": 0,
            "units": {
              "en": "10"
            },
            "placeholder": {
              "en": "Choose between 1 and 120 Minutes"
            }
          }
        ],
        "id": "start-boost-timer"
      },
      {
        "title": {
          "en": "Activate Constant Speed Mode"
        },
        "titleFormatted": {
          "en": "Activate the fan in Constant Speed Mode at [[rpm]] RPM"
        },
        "hint": {
          "en": "When activated, your fan will activate in Constant Speed Mode without a timer until it has been deactivated"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sky"
          },
          {
            "type": "number",
            "name": "rpm",
            "title": {
              "en": "RPM"
            },
            "min": 800,
            "max": 2400,
            "decimals": 0,
            "units": {
              "en": "RPM"
            },
            "placeholder": {
              "en": "Choose between 800–2400"
            }
          }
        ],
        "id": "start-constant-speed-rpm"
      },
      {
        "title": {
          "en": "Deactivate Constant Speed Mode"
        },
        "titleFormatted": {
          "en": "Deactivate Constant Speed Mode"
        },
        "hint": {
          "en": "When activated, your fan will deactivate Constant Speed Mode"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sky"
          }
        ],
        "id": "stop-constant-speed"
      }
    ]
  },
